{
  "name": "dlo-workspace",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit && pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "dev": "pnpm -r dev",
    "dlo:init": "pnpm -C packages/cli run init",
    "dlo:run": "pnpm -C packages/cli run start"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "^6.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
