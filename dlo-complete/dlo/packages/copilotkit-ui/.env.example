# ── Google Gemini ────────────────────────────────────────────────
# Used for Deep Research phase and CopilotKit chat
GEMINI_API_KEY=

# Optional: override the default Copilot chat model
# GEMINI_COPILOT_MODEL=gemini-2.5-flash

# ── Anthropic ────────────────────────────────────────────────────
# Used for Planning and Supervisor agents (Claude Code)
ANTHROPIC_API_KEY=

# ── DeepSeek / CodeWhale ─────────────────────────────────────────
# Used for code execution modules
DEEPSEEK_API_KEY=

# ── Pi.dev ───────────────────────────────────────────────────────
# Used for test harness subagents (optional — local shims available)
PI_API_KEY=

# ── App ──────────────────────────────────────────────────────────
# Public URL of the running DLO server (defaults to window.location.origin)
NEXT_PUBLIC_DLO_DAEMON_URL=http://localhost:8090

# Port (default 8090)
# PORT=8090
